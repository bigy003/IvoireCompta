# IvoireCompta — Variables d'environnement
# Copier en .env et remplir les valeurs

# ── Base de données ──────────────────────────────────────────────
DATABASE_URL="postgresql://ivoirecompta:password@localhost:5432/ivoirecompta_dev"

# ── Cache & Jobs ─────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Auth ─────────────────────────────────────────────────────────
JWT_SECRET="changez-moi-en-production-minimum-64-caracteres-aleatoires"
JWT_REFRESH_SECRET="autre-secret-pour-refresh-tokens"

# ── API ──────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# ── AWS S3 (documents) ───────────────────────────────────────────
AWS_REGION="af-south-1"
AWS_BUCKET_DOCUMENTS="ivoirecompta-documents-dev"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ── Email (SendGrid) ─────────────────────────────────────────────
SENDGRID_API_KEY=""
EMAIL_FROM="noreply@ivoirecompta.ci"
EMAIL_FROM_NAME="IvoireCompta"

# ── WhatsApp Business API ────────────────────────────────────────
WHATSAPP_API_URL="https://api.whatsapp.com/v1"
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_ID=""

# ── e-impôts.gouv.ci (à configurer quand API disponible) ─────────
EIMPOTS_API_URL="https://api.e-impots.gouv.ci/v1"
EIMPOTS_API_KEY=""

# ── Paiements Mobile Money ───────────────────────────────────────
CINETPAY_API_KEY=""
CINETPAY_SITE_ID=""
